  "regexRules": [
    {
      "pattern": "^Better $",
      "flags": "i",
      "replacement": "更好"
    },
    {
      "pattern": "^, better$",
      "flags": "i",
      "replacement": " 更高"
    },
    {
      "pattern": "^(\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?)\\s*context$",
      "flags": "i",
      "replacement": " 上下文"
    },
    {
      "pattern": "^, no subscriptions\\.$",
      "flags": "i",
      "replacement": "，无需订阅。"
    },
    {
      "pattern": "^(\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?)\\s*Monthly Tokens$",
      "flags": "i",
      "replacement": "$1 月度 Tokens"
    },
    {
      "pattern": "^active models on$",
      "flags": "i",
      "replacement": "个活跃模型，"
    },
    {
      "pattern": "^prices$",
      "flags": "i",
      "replacement": "价格"
    },
    {
      "pattern": "^uptime$",
      "flags": "i",
      "replacement": "可用性"
    },
    {
      "pattern": "^Hiring$",
      "flags": "i",
      "replacement": ""
    },
    {
      "pattern": "^providers$",
      "flags": "i",
      "replacement": "服务商"
    },
    {
      "pattern": "^New$",
      "flags": "i",
      "replacement": "新"
    },
    {
      "pattern": "^(\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?)\\+\\s*Active Providers$",
      "flags": "i",
      "replacement": "$1+ 活跃服务商"
    },
    {
      "pattern": "^(\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?)\\+\\s*Models$",
      "flags": "i",
      "replacement": "$1+ 个模型"
    },
    {
      "pattern": "^(\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?)\\+\\s*Global Users$",
      "flags": "i",
      "replacement": "$1+ 全球用户"
    },
    {
      "pattern": "^(\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?)\\s*Monthly Tokens$",
      "flags": "i",
      "replacement": "$1 月度 Tokens"
    },
    {
      "pattern": "^(?:\\d+(?:[\\.,]\\d+)?[TGBMK]?\\+?\\s*)?Weekly Trend\\s*([+-]?\\d+(?:[\\.,]\\d+)?%)$",
      "flags": "i",
      "replacement": "周趋势 $1"
    },
    {
      "pattern": "^View models$",
      "flags": "i",
      "replacement": "查看模型"
    },
    {
      "pattern": "^View rankings$",
      "flags": "i",
      "replacement": "查看排行榜"
    },
    {
      "pattern": "^View docs$",
      "flags": "i",
      "replacement": "查看文档"
    },
    {
      "pattern": "^models$",
      "flags": "i",
      "replacement": "个模型"
    },
    {
      "pattern": "^\\d+[kmb]\\+\\s*apps\\s*using\\s*OpenRouter\\s*with\\s*[\\d.]+[kmb]\\+\\s*users\\s*globally$",
      "flags": "i",
      "replacement": "使用 OpenRouter 的应用，全球用户"
    },
    {
      "pattern": "^Jan\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年1月$1日"
    },
    {
      "pattern": "^Feb\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年2月$1日"
    },
    {
      "pattern": "^Mar\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年3月$1日"
    },
    {
      "pattern": "^Apr\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年4月$1日"
    },
    {
      "pattern": "^May\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年5月$1日"
    },
    {
      "pattern": "^Jun\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年6月$1日"
    },
    {
      "pattern": "^Jul\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年7月$1日"
    },
    {
      "pattern": "^Aug\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年8月$1日"
    },
    {
      "pattern": "^Sep\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年9月$1日"
    },
    {
      "pattern": "^Oct\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年10月$1日"
    },
    {
      "pattern": "^Nov\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年11月$1日"
    },
    {
      "pattern": "^Dec\\s+(\\d{1,2}),\\s+(\\d{4})$",
      "flags": "",
      "replacement": "$2年12月$1日"
    }
  ]
